---
import { site } from '../config/site';
import '../styles/global.css';
import '../styles/enhancements.css';
import '../styles/certifications.css';
interface Crumb { name: string; url: string; }
interface Props { title: string; description: string; path?: string; image?: string; breadcrumbs?: Crumb[]; schema?: Record<string, unknown> | Record<string, unknown>[]; ogType?: string; }
const { title, description, path = Astro.url.pathname, image = '/images/scenes/transformer-substation-hero.png', breadcrumbs = [], schema, ogType = 'website' } = Astro.props;
const canonical = new URL(path, site.siteUrl).toString();
const absoluteImage = new URL(image, site.siteUrl).toString();
const crumbSchema = breadcrumbs.length ? {'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:breadcrumbs.map((crumb,index)=>({'@type':'ListItem',position:index+1,name:crumb.name,item:new URL(crumb.url,site.siteUrl).toString()}))} : null;
const schemas = [...(Array.isArray(schema) ? schema : schema ? [schema] : []), ...(crumbSchema ? [crumbSchema] : [])];
const nav = [['Products','/products/'],['Applications','/applications/'],['Blog','/blog/'],['OEM','/oem-customization/'],['Certifications','/certifications/'],['About','/about/'],['Contact','/contact/']];
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><title>{title}</title><meta name="description" content={description}><link rel="canonical" href={canonical}><meta name="robots" content="index,follow,max-image-preview:large"><meta property="og:type" content={ogType}><meta property="og:title" content={title}><meta property="og:description" content={description}><meta property="og:url" content={canonical}><meta property="og:site_name" content={site.name}><meta property="og:image" content={absoluteImage}><meta name="twitter:card" content="summary_large_image"><meta name="theme-color" content="#081f35"><link rel="icon" href="/favicon.svg" type="image/svg+xml">{schemas.map(item => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)}/>)}</head>
<body><a class="skip" href="#main">Skip to content</a><header class="site-header"><div class="utility"><div class="container"><span>Oil-immersed transformer temperature indication and monitoring</span><a href={`mailto:${site.email}`}>{site.email}</a></div></div><div class="container nav-wrap"><a class="brand" href="/" aria-label="INNO home"><img src="/images/logo/inno-logo.png" alt="INNO" width="146" height="55"></a><button class="menu" aria-expanded="false" aria-controls="primary-navigation">Menu</button><nav id="primary-navigation" aria-label="Primary"><a href="/">Home</a>{nav.map(([label,url]) => <a href={url}>{label}</a>)}</nav></div></header>
<main id="main">{breadcrumbs.length > 0 && <nav class="breadcrumbs container" aria-label="Breadcrumb">{breadcrumbs.map((crumb,index) => <><a href={crumb.url}>{crumb.name}</a>{index < breadcrumbs.length - 1 && <span>/</span>}</>)}</nav>}<slot/></main>
<footer><div class="container footer-grid"><div><img src="/images/logo/inno-logo.png" alt="INNO" width="140" height="53"><p>Focused oil and winding temperature indication, control and remote monitoring for oil-immersed transformers.</p></div><div><h2>Products</h2><a href="/products/transformer-oil-temperature-indicators/">Oil temperature indicators</a><a href="/products/transformer-winding-temperature-indicators/">Winding indicators</a><a href="/products/transformer-temperature-monitoring-devices/">Monitoring devices</a></div><div><h2>Resources</h2><a href="/applications/">Applications</a><a href="/blog/">Technical blog</a><a href="/certifications/">Certifications</a><a href="/quality-control/">Quality control</a><a href="/sitemap/">Sitemap</a></div><div><h2>Contact</h2><p>Technical and commercial inquiries are handled by email.</p><a href={`mailto:${site.email}`}>{site.email}</a><a href="/privacy-policy/">Privacy policy</a></div></div><div class="container copyright">© 2026 INNO. Product configurations and specifications must be confirmed for the selected model.</div></footer>
<script is:inline>const button=document.querySelector('.menu');const nav=document.querySelector('#primary-navigation');button?.addEventListener('click',()=>{const expanded=button.getAttribute('aria-expanded')==='true';button.setAttribute('aria-expanded',String(!expanded));nav?.classList.toggle('open')});</script></body></html>
