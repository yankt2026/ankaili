---
import Base from '../../layouts/BaseLayout.astro';
import EmailCTA from '../../components/EmailCTA.astro';
import { applications,type Application } from '../../data/applications';
import { products } from '../../data/products';
export function getStaticPaths(){return applications.map(page=>({params:{slug:page.slug},props:{page}}));}
const {page}=Astro.props as {page:Application};
const related=products.filter(product=>page.productSlugs.includes(product.slug));
const crumbs=[{name:'Home',url:'/'},{name:'Applications',url:'/applications/'},{name:page.title,url:`/applications/${page.slug}/`}];
const schema={'@context':'https://schema.org','@type':'Service',name:page.title,description:page.description,provider:{'@type':'Organization',name:'INNO'},areaServed:'Worldwide',serviceType:'Transformer temperature monitoring application engineering'};
---
<Base title={page.seoTitle} description={page.description} breadcrumbs={crumbs} schema={schema}>
  <section class="page-hero"><div class="container"><p class="eyebrow">Transformer monitoring application</p><h1>{page.title}</h1><p>{page.intro}</p></div></section>
  <section class="section"><article class="container prose"><h2>How Does {page.title} Work?</h2><div class="answer-block">{page.answer}</div>{page.sections.map(section=><section><h2>{section.heading}</h2>{section.body.map(text=><p>{text}</p>)}</section>)}<h2>Checks Before Model Selection</h2><div class="grid two">{page.risks.map(risk=><div class="card"><h3>{risk}</h3></div>)}</div></article></section>
  <section class="section tint"><div class="container"><div class="section-head"><h2>Transformer Temperature Products for This Application</h2><p class="lead">Compare the measured variable, contacts, signal and mechanical interface before choosing the final model.</p></div><div class="grid two">{related.map(product=><article class="card"><a href={`/products/${product.slug}/`}><img src={product.image} alt={`${product.model} for ${page.title.toLowerCase()}`} width="800" height="800" loading="lazy"></a><h3><a href={`/products/${product.slug}/`}>{product.name}</a></h3><p>{product.summary}</p><a class="arrow" href={`/products/${product.slug}/`}>Review {product.model} technical data</a></article>)}</div></div></section>
  <EmailCTA title={`Plan ${page.title}`} subject={`${page.title} product selection request`} />
</Base>
