---
import Base from '../layouts/BaseLayout.astro';
import EmailCTA from '../components/EmailCTA.astro';
const management=[
  {file:'iso-9001.jpg',title:'ISO 9001 Quality Management',text:'Quality management system certificate covering the scope stated on the displayed document.'},
  {file:'iso-14001.jpg',title:'ISO 14001 Environmental Management',text:'Environmental management system documentation for supplier qualification review.'},
  {file:'iso-45001.jpg',title:'ISO 45001 Occupational Health and Safety',text:'Management system certificate addressing occupational health and safety controls.'},
  {file:'iso-27001.jpg',title:'ISO 27001 Information Security Management',text:'Information security management system document for organizational due diligence.'}
];
const compliance=[
  {file:'ce-emc.jpg',title:'CE EMC Conformity Document',text:'A conformity document referencing electromagnetic compatibility standards for the products named in that certificate.'},
  {file:'ce-lvd.jpg',title:'CE LVD Conformity Document',text:'A conformity document referencing low-voltage requirements for the products and models listed on that document.'},
  {file:'rohs.jpg',title:'RoHS Conformity Document',text:'Documentation addressing restricted substances for the product scope identified in the certificate.'}
];
const reports=[
  {file:'inspection-report-switchgear.jpg',title:'Integrated Switchgear Inspection Report',text:'Third-party report material for a fluorescent fiber-optic temperature measurement application.'},
  {file:'withstand-voltage-test-report.jpg',title:'Power-Frequency Withstand-Voltage Test Report',text:'Test-report material related to the high-voltage performance of a fiber-optic temperature sensing system.'},
  {file:'type-inspection-report.jpg',title:'Temperature Monitoring System Type Inspection',text:'Type-inspection documentation for a fluorescent fiber temperature online monitoring system.'}
];
const honors=[
  ['honor-01.jpg','Industry-University-Research Cooperation Base'],['honor-02.jpg','Innovative SME Recognition'],['honor-03.jpg','High-Tech Enterprise Recognition'],['honor-04.jpg','Enterprise Qualification Document'],['honor-05.jpg','Technology Little Giant Recognition'],['honor-06.jpg','Technology-Oriented SME Recognition'],['honor-07.jpg','Enterprise Honor Document'],['honor-08.jpg','Transformer Accessory Industry Recognition'],['honor-09.jpg','Specialized and Innovative Enterprise Recognition'],['honor-10.jpg','Invention Patent Portfolio']
];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Certifications and Qualification Documents',description:'Management system certificates, conformity documents, inspection reports, company qualifications and patent materials available for INNO supplier qualification.',url:'https://ankaili.com/certifications/'};
---
<Base title="Transformer Controller Certifications & Quality | INNO" description="Review INNO quality-management certificates, conformity documents, inspection reports and qualifications for transformer temperature controller supplier evaluation." schema={schema}>
  <section class="page-hero"><div class="container"><p class="eyebrow">Quality documentation</p><h1>Certifications and Qualification Documents</h1><p>Review management-system certificates, conformity documents, inspection reports and enterprise qualification materials for procurement due diligence.</p></div></section>
  <section class="section"><div class="container cert-intro"><div class="prose"><h2>Documents should be checked against the order</h2><p>Certification review is part of technical and commercial qualification. The issuing organization, certificate holder, covered scope, referenced standard, validity period and applicable product models should all be checked before a document is used in a tender or approval package.</p><p>The documents displayed here do not mean that every certificate applies to every transformer oil temperature indicator, winding temperature indicator or selected model. Email the required market, standard and model list to request the current documents applicable to your order.</p></div><aside class="notice"><strong>Procurement note</strong><p>Ask for a current, readable certificate copy and confirm its scope against the final model code. Project-specific inspection or test documentation should be agreed before ordering.</p></aside></div></section>
  <section class="section tint"><div class="container"><div class="section-head"><p class="eyebrow">Management systems</p><h2>ISO Management System Certificates</h2><p class="lead">Organizational management certificates can support supplier qualification, but they are different from product-model approval.</p></div><div class="certificate-grid">{management.map((item,index)=><article class:list={["certificate-card",index===0&&"certificate-feature"]}><a href={`/images/certifications/${item.file}`} target="_blank"><img src={`/images/certifications/${item.file}`} alt={`${item.title} certificate document`} width="720" height="980" loading="lazy"></a><div><h3>{item.title}</h3><p>{item.text}</p><a class="arrow" href={`/images/certifications/${item.file}`} target="_blank">View document</a></div></article>)}</div></div></section>
  <section class="section"><div class="container"><div class="section-head"><p class="eyebrow">Market documentation</p><h2>CE and RoHS Conformity Materials</h2><p class="lead">Conformity documents must be matched to the product name, model list and directive shown on the document.</p></div><div class="certificate-grid compact">{compliance.map(item=><article class="certificate-card"><a href={`/images/certifications/${item.file}`} target="_blank"><img src={`/images/certifications/${item.file}`} alt={`${item.title} document`} width="720" height="980" loading="lazy"></a><div><h3>{item.title}</h3><p>{item.text}</p><a class="arrow" href={`/images/certifications/${item.file}`} target="_blank">View document</a></div></article>)}</div></div></section>
  <section class="section tint"><div class="container"><div class="section-head"><p class="eyebrow">Verification evidence</p><h2>Inspection and Test Reports</h2><p class="lead">Reports provide evidence for the samples and systems identified in each document. They should not be generalized to an unrelated model.</p></div><div class="certificate-grid compact">{reports.map(item=><article class="certificate-card"><a href={`/images/certifications/${item.file}`} target="_blank"><img src={`/images/certifications/${item.file}`} alt={`${item.title} cover`} width="724" height="1024" loading="lazy"></a><div><h3>{item.title}</h3><p>{item.text}</p><a class="arrow" href={`/images/certifications/${item.file}`} target="_blank">View report cover</a></div></article>)}</div></div></section>
  <section class="section"><div class="container"><div class="section-head"><p class="eyebrow">Company qualifications</p><h2>Enterprise Honors and Patent Materials</h2><p class="lead">These materials provide additional organizational background for supplier evaluation and research capability review.</p></div><div class="honor-grid">{honors.map(([file,title])=><figure><a href={`/images/certifications/${file}`} target="_blank"><img src={`/images/certifications/${file}`} alt={title} width="946" height="640" loading="lazy"></a><figcaption>{title}</figcaption></figure>)}</div></div></section>
  <section class="section tint"><article class="container prose"><h2>What to request for a transformer temperature controller order</h2><ul><li>The current business and quality-management documents required by your supplier approval process</li><li>Product conformity documents whose scope explicitly includes the selected product and model</li><li>The model-specific datasheet, outline drawing and terminal diagram</li><li>Inspection records or certificates of conformity agreed for the order</li><li>Any destination-market documents required by the importer or project specification</li></ul><p>Requirements vary by country, industry and project. The buyer, importer and project authority remain responsible for confirming which documents are required for market access or final acceptance.</p></article></section>
  <EmailCTA title="Request Documents for Your Model" subject="Transformer temperature product certification and document request" />
</Base>
