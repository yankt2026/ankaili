---
import Base from '../../layouts/BaseLayout.astro';
import EmailCTA from '../../components/EmailCTA.astro';
import { blogs } from '../../data/blogs';
---
<Base title="Transformer Temperature Monitoring Guides | INNO" description="Read technical guides for transformer temperature monitoring systems, OTI and WTI selection, BWY and BWR models, wiring, installation and replacement.">
  <section class="page-hero"><div class="container"><p class="eyebrow">Selection and installation resources</p><h1>Transformer OTI, WTI, BWY and BWR Technical Guides</h1><p>Compare models, specify contacts and output signals, plan installation and prepare a complete transformer temperature controller inquiry.</p></div></section>
  <section class="section"><div class="container editorial-grid">{blogs.map((post, index) => <article class:list={["card", index === 0 && "feature-card"]}><p class="eyebrow">{post.category}</p><h2><a href={`/blog/${post.slug}/`}>{post.title}</a></h2><p>{post.description}</p></article>)}</div></section>
  <EmailCTA title="Discuss a Transformer Temperature Requirement" subject="Transformer temperature technical inquiry" />
</Base>
