---
import Base from '../../layouts/BaseLayout.astro';
import EmailCTA from '../../components/EmailCTA.astro';
import SpecTable from '../../components/SpecTable.astro';
import { products, type Product } from '../../data/products';
import { site } from '../../config/site';
export function getStaticPaths(){return products.map(product=>({params:{slug:product.slug},props:{product}}));}
const { product }=Astro.props as {product:Product};
const categoryUrl=`/products/${product.categorySlug}/`;
const crumbs=[{name:'Home',url:'/'},{name:'Products',url:'/products/'},{name:product.name,url:`/products/${product.slug}/`}];
const schema={'@context':'https://schema.org','@type':'Product',name:product.name,model:product.model,description:product.summary,image:[new URL(product.image,site.siteUrl).toString(),new URL(product.detailImage,site.siteUrl).toString()],brand:{'@type':'Brand',name:'INNO'},manufacturer:{'@type':'Organization',name:'INNO',url:site.siteUrl},category:product.category,url:new URL(`/products/${product.slug}/`,site.siteUrl).toString()};
---
<Base title={product.title} description={product.description} image={product.image} breadcrumbs={crumbs} schema={schema}>
  <section class="page-hero"><div class="container product-hero"><div><p class="eyebrow">{product.category} manufacturer</p><h1>{product.name}</h1><p>{product.summary}</p><div class="actions"><a class="button" href={`mailto:${site.email}?subject=${encodeURIComponent(`${product.model} datasheet and quotation request`)}`}>Request {product.model} data</a><a class="text-link" href="#specifications">Review {product.model} specifications</a></div></div><img src={product.image} alt={`${product.model} ${product.name} front product view`} width="800" height="800"></div></section>
  <section class="section"><div class="container"><div class="section-head"><h2>{product.model} Functions for Transformer Temperature Control</h2><p class="lead">Confirm how the selected configuration will indicate temperature, operate contacts and communicate with the remote system.</p></div><div class="grid">{product.featured.map(item=><article class="card metric"><h3>{item}</h3><p>The final implementation follows the confirmed model code, outline drawing and terminal diagram.</p></article>)}</div></div></section>
  <section class="section tint" id="specifications"><div class="container"><div class="section-head"><h2>{product.model} Technical Specifications</h2><p class="lead">Use these values for initial comparison, then confirm the selected suffix, options and project interfaces in the current model documents.</p></div><SpecTable specs={product.specs} caption={`${product.model} transformer temperature controller specifications`} /></div></section>
  <section class="section"><article class="container prose"><h2>{product.model} Product Overview</h2>{product.overview.map(text=><p>{text}</p>)}<img src={product.detailImage} alt={`${product.model} transformer temperature controller detail and installation components`} width="1000" height="750" loading="lazy"><h2>How Does the {product.model} Temperature Measurement Work?</h2>{product.principle.map(text=><p>{text}</p>)}<h2>How to Select the {product.model}</h2>{product.selection.map(text=><p>{text}</p>)}<h2>{product.model} Installation and Commissioning</h2>{product.installation.map(text=><p>{text}</p>)}<h2>{product.model} Transformer Applications</h2><div class="grid two">{product.applications.map(item=><div class="card"><h3>{item}</h3><p>Confirm the measurement point, contact logic, output and mechanical interface against the transformer project documents.</p></div>)}</div><p class="source-note">Specifications and available options vary by model configuration. Request the current datasheet, outline drawing and terminal diagram before approving an order.</p></article></section>
  <section class="section tint"><div class="container"><div class="section-head"><h2>Related {product.model} Selection Resources</h2></div><div class="grid two"><article class="card"><h3>Compare the Product Category</h3><p>Review other models for the same transformer temperature measurement and control function.</p><a class="arrow" href={categoryUrl}>Compare {product.category.toLowerCase()}</a></article><article class="card"><h3>Plan Cooling, Alarm and Trip Control</h3><p>Review how OTI and WTI contacts support transformer cooling stages and protection logic.</p><a class="arrow" href="/applications/transformer-cooling-control-alarm-trip/">Transformer cooling and protection application</a></article><article class="card"><h3>Prepare a Replacement</h3><p>Compare existing codes, outputs, capillary routing and mounting interfaces before a controller replacement.</p><a class="arrow" href="/blog/replace-transformer-oil-winding-temperature-indicator/">Transformer OTI and WTI replacement guide</a></article><article class="card"><h3>Review Supplier Documents</h3><p>Check available management-system, conformity and qualification materials for procurement review.</p><a class="arrow" href="/certifications/">Certification and qualification documents</a></article></div></div></section>
  <EmailCTA title={`Request ${product.model} Selection and Pricing`} subject={`${product.model} datasheet, selection and quotation request`} label={`Email about ${product.model}`} />
</Base>
