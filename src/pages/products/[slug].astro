---
import Base from '../../layouts/BaseLayout.astro';
import EmailCTA from '../../components/EmailCTA.astro';
import SpecTable from '../../components/SpecTable.astro';
import { products, type Product } from '../../data/products';
import { site } from '../../config/site';
export function getStaticPaths(){return products.map(product=>({params:{slug:product.slug},props:{product}}));}
const { product } = Astro.props as { product: Product };
const crumbs=[{name:'Home',url:'/'},{name:'Products',url:'/products/'},{name:product.name,url:`/products/${product.slug}/`}];
const schema={'@context':'https://schema.org','@type':'Product',name:product.name,model:product.model,description:product.summary,image:[new URL(product.image,site.siteUrl).toString(),new URL(product.detailImage,site.siteUrl).toString()],brand:{'@type':'Brand',name:'INNO'},manufacturer:{'@type':'Organization',name:'INNO',url:site.siteUrl},category:product.category,url:new URL(`/products/${product.slug}/`,site.siteUrl).toString()};
---
<Base title={product.title} description={product.description} image={product.image} breadcrumbs={crumbs} schema={schema}>
  <section class="page-hero"><div class="container product-hero"><div><p class="eyebrow">{product.category}</p><h1>{product.name}</h1><p>{product.summary}</p><div class="actions"><a class="button" href={`mailto:${site.email}?subject=${encodeURIComponent(`${product.model} datasheet and quotation request`)}`}>Email for datasheet</a><a class="text-link" href="#specifications">Review technical data</a></div></div><img src={product.image} alt={`${product.model} ${product.name} front product view`} width="800" height="800"></div></section>
  <section class="section"><div class="container"><div class="section-head"><h2>Functions for transformer thermal control</h2></div><div class="grid">{product.featured.map(item=><article class="card metric"><h3>{item}</h3><p>The final implementation follows the confirmed model code, drawing and terminal diagram.</p></article>)}</div></div></section>
  <section class="section tint" id="specifications"><div class="container"><div class="section-head"><h2>Referenced technical specifications</h2><p class="lead">These values were collected from the referenced product material. Confirm every value for the selected model before design approval or purchase.</p></div><SpecTable specs={product.specs} caption={`${product.model} specifications`} /></div></section>
  <section class="section"><article class="container prose"><h2>Product overview</h2>{product.overview.map(text=><p>{text}</p>)}<img src={product.detailImage} alt={`${product.model} transformer temperature controller detail and installation components`} width="1000" height="750" loading="lazy"><h2>How the measurement works</h2>{product.principle.map(text=><p>{text}</p>)}<h2>What should be confirmed before selection?</h2>{product.selection.map(text=><p>{text}</p>)}<h2>Installation and commissioning approach</h2>{product.installation.map(text=><p>{text}</p>)}<h2>Typical applications</h2><div class="grid two">{product.applications.map(item=><div class="card"><h3>{item}</h3><p>Confirm the model, measurement point, contact logic and output against the transformer project documents.</p></div>)}</div><p class="source-note">Specifications and available options vary by model configuration. Request the current datasheet, outline drawing and terminal diagram before approving an order.</p></article></section>
  <section class="section tint"><div class="container grid two"><article class="card"><h2>Related application guidance</h2><p>Review how OTI and WTI instruments support cooling control, alarm, trip and remote indication.</p><a class="arrow" href="/applications/transformer-cooling-control-alarm-trip/">Transformer control application</a></article><article class="card"><h2>Selection and replacement guide</h2><p>Compare existing model codes, outputs, capillary routing and mounting interfaces before replacement.</p><a class="arrow" href="/blog/replace-transformer-oil-winding-temperature-indicator/">Read the replacement checklist</a></article></div></section>
  <EmailCTA title={`Specify the ${product.model}`} subject={`${product.model} datasheet, selection and quotation request`} label={`Email about ${product.model}`} />
</Base>
