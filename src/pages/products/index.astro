---
import Base from '../../layouts/BaseLayout.astro';
import EmailCTA from '../../components/EmailCTA.astro';
import { products } from '../../data/products';
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Transformer Temperature Products',description:'INNO oil and winding temperature indicators and monitoring devices for oil-immersed transformers.'};
---
<Base title="Transformer Temperature Products | INNO" description="Compare INNO transformer oil temperature indicators, winding temperature indicators and integrated oil monitoring devices for oil-immersed transformers." schema={schema}>
  <section class="page-hero"><div class="container"><p class="eyebrow">Product portfolio</p><h1>Transformer Temperature Products</h1><p>Choose a local oil temperature indicator, simulated winding temperature indicator or powered multi-parameter monitoring device according to the measurement, control and remote-signal requirement.</p></div></section>
  <section class="section"><div class="container"><div class="section-head"><h2>Match the instrument to the measured value</h2><p class="lead">OTI, WTI and digital monitoring devices answer different engineering questions. Start with what must be measured and what the signal must operate.</p></div><div class="grid">{products.map(product => <article class="card"><a href={`/products/${product.slug}/`}><img src={product.image} alt={`${product.model} transformer temperature instrument`} width="560" height="420" loading="lazy"></a><p class="eyebrow">{product.category}</p><h2><a href={`/products/${product.slug}/`}>{product.name}</a></h2><p>{product.summary}</p><a class="arrow" href={`/products/${product.slug}/`}>Review specifications</a></article>)}</div></div></section>
  <section class="section tint"><div class="container grid two"><article class="card metric"><h2>Oil temperature indicators</h2><p>Measure top-oil temperature and operate cooling or alarm contacts with BWY and BWY2 instruments.</p><a class="arrow" href="/products/transformer-oil-temperature-indicators/">Compare OTI models</a></article><article class="card metric"><h2>Winding temperature indicators</h2><p>Simulate winding temperature from top-oil temperature and transformer load using BWR and BWR2 systems.</p><a class="arrow" href="/products/transformer-winding-temperature-indicators/">Compare WTI models</a></article><article class="card metric"><h2>Monitoring devices</h2><p>Acquire oil temperature together with level and pressure for remote transformer monitoring.</p><a class="arrow" href="/products/transformer-temperature-monitoring-devices/">Review monitoring devices</a></article><article class="card metric"><h2>Selection support</h2><p>Send the existing model, drawing and required outputs for a new project or replacement review.</p><a class="arrow" href="/contact/">Prepare an email inquiry</a></article></div></section>
  <EmailCTA subject="Transformer temperature product selection" />
</Base>
