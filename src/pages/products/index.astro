---
import Base from '../../layouts/BaseLayout.astro';
import EmailCTA from '../../components/EmailCTA.astro';
import { products } from '../../data/products';
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Transformer Temperature Controllers and Monitoring Devices',description:'OTI, WTI, BWY, BWR and transformer temperature monitoring devices for oil-immersed transformer projects.'};
---
<Base title="Transformer Temperature Controllers & Monitors | INNO" description="Compare OTI and WTI transformer temperature controllers, BWY oil indicators, BWR winding indicators and monitoring devices. Request model documents." schema={schema}>
  <section class="page-hero"><div class="container"><p class="eyebrow">Oil-immersed transformer products</p><h1>Transformer Temperature Controllers and Monitoring Devices</h1><p>Compare local oil temperature indicators, simulated winding temperature indicators and powered monitoring devices for cooling, alarm, trip and remote indication.</p></div></section>
  <section class="section"><div class="container"><div class="answer-block"><strong>Product selection answer.</strong> Choose an OTI for transformer top-oil temperature, a WTI for traditional simulated winding temperature, or a powered monitoring device when the project requires remote temperature, oil-level or pressure data. Then confirm contacts, output, mechanics and the complete model code.</div><div class="section-head"><h2>Compare BWY, BWR, OTI and WTI Models</h2><p class="lead">Each model page provides product images, functions, technical data, selection inputs and application guidance.</p></div><div class="grid">{products.map(product => <article class="card"><a href={`/products/${product.slug}/`}><img src={product.image} alt={`${product.model} transformer temperature controller or monitoring device`} width="560" height="420" loading="lazy"></a><p class="eyebrow">{product.category}</p><h3><a href={`/products/${product.slug}/`}>{product.name}</a></h3><p>{product.summary}</p><a class="arrow" href={`/products/${product.slug}/`}>Review {product.model} technical data</a></article>)}</div></div></section>
  <section class="section tint"><div class="container"><div class="section-head"><h2>Choose a Transformer Temperature Product Category</h2></div><div class="grid two"><article class="card metric"><h3>Oil Temperature Indicators (OTI)</h3><p>Measure top-oil temperature and operate cooling or alarm contacts with BWY and BWY2 transformer oil temperature controllers.</p><a class="arrow" href="/products/transformer-oil-temperature-indicators/">Compare OTI and BWY models</a></article><article class="card metric"><h3>Winding Temperature Indicators (WTI)</h3><p>Indicate simulated winding temperature from top oil and transformer load using BWR and BWR2 winding temperature controllers.</p><a class="arrow" href="/products/transformer-winding-temperature-indicators/">Compare WTI and BWR models</a></article><article class="card metric"><h3>Transformer Monitoring Systems and Devices</h3><p>Acquire transformer oil temperature, level and pressure for a compatible remote display or supervisory system.</p><a class="arrow" href="/products/transformer-temperature-monitoring-devices/">Review remote monitoring devices</a></article><article class="card metric"><h3>OEM, Replacement and Supplier Support</h3><p>Send the existing model, transformer drawing and required outputs for configuration, replacement and quotation review.</p><a class="arrow" href="/oem-customization/">Review custom controller options</a></article></div></div></section>
  <section class="section"><article class="container prose"><h2>What information does a transformer temperature controller supplier need?</h2><p>Provide the measured variable, temperature range, switch quantity and duty, remote signal, power supply, capillary length, bulb, mounting thread, installation environment, quantity and destination country. For a direct replacement, include the full nameplate, dial, terminals, installed capillary route and mounting dimensions.</p><h3>Request current technical and qualification documents</h3><p>Use the selected model page to prepare the requirement, review the <a href="/certifications/">certification and qualification documents</a>, and email INNO for the current datasheet, outline drawing, terminal diagram and quotation.</p></article></section>
  <EmailCTA title="Select a Transformer Temperature Controller" subject="Transformer temperature controller and monitoring device selection" />
</Base>
