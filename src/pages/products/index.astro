---
import Base from '../../layouts/BaseLayout.astro';
import EmailCTA from '../../components/EmailCTA.astro';
import { products } from '../../data/products';
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Transformer Temperature Controllers and Monitoring Devices',description:'OTI, WTI, BWY, BWR and transformer temperature monitoring devices for oil-immersed transformer projects.'};
---
<Base title="Transformer Temperature Controllers & Monitors | INNO" description="Compare OTI and WTI transformer temperature controllers, BWY oil indicators, BWR winding indicators and monitoring devices. Request model documents." schema={schema}>
  <section class="page-hero"><div class="container"><p class="eyebrow">Transformer temperature products</p><h1>Transformer Temperature Controllers and Monitoring Devices</h1><p>Compare OTI oil temperature indicators, WTI winding temperature indicators and digital monitoring devices for oil-immersed transformers.</p></div></section>
  <section class="section"><div class="container"><div class="answer-block">Choose an OTI to measure transformer top-oil temperature. Choose a WTI for simulated winding temperature and load-related cooling control. For remote oil temperature, level and pressure data, choose a powered monitoring device with a compatible digital connection.</div><div class="section-head"><h2>Browse BWY, BWR, OTI and WTI Models</h2><p class="lead">Open a model page to see product photos, specifications, output options, installation details and the information needed for a quote.</p></div><div class="grid">{products.map(product => <article class="card"><a href={`/products/${product.slug}/`}><img src={product.image} alt={`${product.model} transformer temperature controller or monitoring device`} width="560" height="420" loading="lazy"></a><p class="eyebrow">{product.category}</p><h3><a href={`/products/${product.slug}/`}>{product.name}</a></h3><p>{product.summary}</p><a class="arrow" href={`/products/${product.slug}/`}>{product.model} specifications</a></article>)}</div></div></section>
  <section class="section tint"><div class="container"><div class="section-head"><h2>Choose a Transformer Temperature Product Category</h2></div><div class="grid two"><article class="card metric"><h3>Oil Temperature Indicators (OTI)</h3><p>Measure top-oil temperature and operate cooling or alarm contacts with BWY and BWY2 transformer oil temperature controllers.</p><a class="arrow" href="/products/transformer-oil-temperature-indicators/">Compare OTI and BWY models</a></article><article class="card metric"><h3>Winding Temperature Indicators (WTI)</h3><p>Indicate simulated winding temperature from top oil and transformer load using BWR and BWR2 winding temperature controllers.</p><a class="arrow" href="/products/transformer-winding-temperature-indicators/">Compare WTI and BWR models</a></article><article class="card metric"><h3>Transformer Monitoring Systems and Devices</h3><p>Acquire transformer oil temperature, level and pressure for a compatible remote display or supervisory system.</p><a class="arrow" href="/products/transformer-temperature-monitoring-devices/">Review remote monitoring devices</a></article><article class="card metric"><h3>OEM, Replacement and Supplier Support</h3><p>Send the existing model, transformer drawing and required outputs for configuration, replacement and quotation review.</p><a class="arrow" href="/oem-customization/">Review custom controller options</a></article></div></div></section>
  <section class="section"><article class="container prose"><h2>What should you send for a price and model recommendation?</h2><p>Send the transformer type, temperature range, number and purpose of contacts, output signal, power supply, capillary length, bulb, mounting thread, quantity and destination country. For a replacement, include photos of the full nameplate, dial, terminals and mounting arrangement.</p><h3>Request the latest product documents</h3><p>Choose a model, check the available <a href="/certifications/">qualification documents</a>, and email INNO for the latest datasheet, outline drawing, terminal diagram and quotation.</p></article></section>
  <EmailCTA title="Request Transformer Controller Datasheets and Pricing" subject="Transformer temperature controller and monitoring device selection" />
</Base>
