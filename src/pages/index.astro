---
import Base from '../layouts/BaseLayout.astro';
import EmailCTA from '../components/EmailCTA.astro';
import { products } from '../data/products';
import { applications } from '../data/applications';
import { site } from '../config/site';
const schema=[
  {'@context':'https://schema.org','@type':'Organization',name:'INNO',url:site.siteUrl,email:site.email,logo:new URL('/images/logo/inno-logo.png',site.siteUrl).toString(),description:'Manufacturer and supplier of transformer temperature monitoring systems, OTI oil temperature indicators, WTI winding temperature indicators and monitoring devices.'},
  {'@context':'https://schema.org','@type':'WebSite',name:site.name,url:site.siteUrl,inLanguage:'en'}
];
---
<Base title="Transformer Temperature Monitoring System Manufacturer | INNO" description="INNO manufactures transformer temperature monitoring systems, OTI and WTI controllers, BWY oil indicators and BWR winding indicators for global projects." schema={schema} image="/images/scenes/transformer-substation-hero.png">
  <section class="hero">
    <img class="hero-scene" src="/images/scenes/transformer-substation-hero.png" alt="Oil-immersed power transformer at a high-voltage substation" width="1792" height="1024">
    <div class="hero-shade"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">OTI, WTI, BWY and BWR manufacturer</p>
        <h1>Transformer Temperature Monitoring Systems and Controllers</h1>
        <p>Choose OTI oil temperature indicators, WTI winding temperature indicators and remote monitoring devices for new transformers, OEM production and replacement projects.</p>
        <div class="actions"><a class="button" href="/products/">View Products and Models</a><a class="text-link" href={`mailto:${site.email}?subject=Transformer%20temperature%20monitoring%20system%20inquiry`}>Request a Datasheet and Quote</a></div>
      </div>
      <div class="hero-panel">
        <img src="/images/products/bwr2-winding-temperature-indicator.webp" alt="BWR2 transformer winding temperature indicator WTI" width="800" height="800">
        <strong>Start with the required measurement</strong>
        <dl><div><dt>Transformer top-oil temperature</dt><dd>OTI / BWY</dd></div><div><dt>Simulated winding temperature</dt><dd>WTI / BWR</dd></div><div><dt>Temperature, level and pressure</dt><dd>Monitoring device</dd></div></dl>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head"><p class="eyebrow">Product range</p><h2>Choose the Right Transformer Temperature Product</h2><p class="lead">Start with the temperature you need to monitor and the action required when it rises.</p></div>
      <div class="grid two">
        <article class="card metric"><h3>Transformer Oil Temperature Indicators (OTI)</h3><p>BWY and BWY2 oil temperature indicators measure transformer top-oil temperature and operate adjustable contacts for cooling or high-temperature alarm.</p><a class="arrow" href="/products/transformer-oil-temperature-indicators/">Compare BWY oil temperature indicators</a></article>
        <article class="card metric"><h3>Transformer Winding Temperature Indicators (WTI)</h3><p>BWR and BWR2 winding temperature indicators combine top-oil sensing with load-current thermal simulation for winding indication and control.</p><a class="arrow" href="/products/transformer-winding-temperature-indicators/">Compare BWR winding temperature indicators</a></article>
        <article class="card metric"><h3>Transformer Monitoring Devices</h3><p>Send oil temperature, oil level and pressure data to a compatible terminal or SCADA system through RS485.</p><a class="arrow" href="/products/transformer-temperature-monitoring-devices/">View monitoring devices</a></article>
        <article class="card metric"><h3>OEM and Replacement Support</h3><p>Match the range, contacts, output, capillary, bulb, thread, mounting and terminal arrangement for new production or replacement work.</p><a class="arrow" href="/oem-customization/">OEM and replacement options</a></article>
      </div>
    </div>
  </section>

  <section class="section tint">
    <div class="container">
      <div class="section-head"><p class="eyebrow">Popular model families</p><h2>BWY Oil and BWR Winding Temperature Controllers</h2><p class="lead">Compare product photos, key specifications and available signals before requesting a datasheet and quotation.</p></div>
      <div class="grid">{products.slice(0,4).map(product=><article class="card"><a href={`/products/${product.slug}/`}><img src={product.image} alt={`${product.model} transformer temperature controller`} width="800" height="800" loading="lazy"></a><p class="eyebrow">{product.model}</p><h3><a href={`/products/${product.slug}/`}>{product.name}</a></h3><p>{product.summary}</p><a class="arrow" href={`/products/${product.slug}/`}>View {product.model} specifications</a></article>)}</div>
    </div>
  </section>

  <section class="section">
    <article class="container prose">
      <p class="eyebrow">How the system works</p>
      <h2>What Is a Transformer Temperature Monitoring System?</h2>
      <div class="answer-block"><strong>A transformer temperature monitoring system</strong> shows top-oil or simulated winding temperature and can start cooling equipment, trigger an alarm or send a signal to a PLC, RTU, SCADA system or remote display. OTI and WTI instruments measure different thermal values and should be selected separately.</div>
      <p>These values are related but not interchangeable. Top-oil temperature describes the oil near the specified thermometer pocket. Simulated winding temperature estimates the additional thermal effect of transformer load. Direct winding hot-spot measurement requires sensors designed into the winding and represents another measurement architecture.</p>
      <h3>How do temperature controllers support transformer protection?</h3>
      <p>Adjustable contacts can start transformer fans or pumps, initiate a high-temperature alarm or provide an input to trip logic. Set points and switching duties must follow the transformer thermal design and protection scheme. The complete control chain includes the temperature instrument, terminal wiring, interposing relays and the final cooling or protection equipment.</p>
      <h3>Which remote signals are available?</h3>
      <p>Common project interfaces include Pt100 resistance output, conditioned 4-20 mA current loops and RS485 communications. Selection must define the signal scale, supply, wiring, shielding, protocol and receiving equipment. A remote signal should always retain the measurement identity, such as top oil or simulated winding temperature.</p>
    </article>
  </section>

  <section class="section tint">
    <div class="container scene-layout">
      <div><img class="scene-image" src="/images/scenes/transformer-temperature-inspection.png" alt="Oil-immersed transformers in an outdoor electrical substation" width="1536" height="1024" loading="lazy"></div>
      <div>
        <div class="section-head"><p class="eyebrow">Applications</p><h2>Where Transformer Temperature Controllers Are Used</h2><p class="lead">Find products for power transformers, distribution transformers, substations, cooling control and retrofit work.</p></div>
        <div class="application-list">{applications.slice(0,4).map((item,index)=><article><span>0{index+1}</span><div><h3><a href={`/applications/${item.slug}/`}>{item.title}</a></h3><p>{item.intro}</p><a class="arrow" href={`/applications/${item.slug}/`}>Review {item.title.toLowerCase()}</a></div></article>)}</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <article class="prose"><p class="eyebrow">For buyers and engineers</p><h2>Request a Datasheet and Quote</h2><p>Send the transformer type, OTI or WTI requirement, existing model, measuring range, contact functions, Pt100, 4-20 mA or RS485 output, power supply, capillary, bulb, thread, quantity and destination country. For a replacement, attach nameplate and terminal photos.</p><div class="actions"><a class="button" href="/contact/">Email Our Sales Team</a><a class="text-link" href="/certifications/">View qualification documents</a></div></article>
      <article class="card"><h3>Focused transformer temperature products</h3><p>INNO supplies oil temperature indicators, winding temperature indicators and monitoring devices for oil-immersed transformers.</p><p><strong>Product groups:</strong> OTI, WTI and integrated monitoring devices.</p><p><strong>Model families:</strong> BWY, BWY2, BWR and BWR2.</p><p><strong>Project types:</strong> new transformers, OEM production and replacements.</p></article>
    </div>
  </section>
  <EmailCTA title="Request a Transformer Temperature Controller Datasheet and Quote" subject="INNO transformer temperature monitoring system inquiry" />
</Base>
