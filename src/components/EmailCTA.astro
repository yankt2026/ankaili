---
import { mailto, site } from '../config/site';
interface Props { title?: string; text?: string; subject?: string; label?: string; }
const {
  title = 'Request a Datasheet and Quote',
  text = 'Tell us the transformer type, required temperature range, contact functions, output signal, capillary length, quantity and destination. We will help you identify a suitable model and send the available technical documents.',
  subject = 'Transformer temperature product inquiry',
  label = 'Email Our Sales Team'
} = Astro.props;
---
<section class="cta">
  <div><p class="eyebrow">Sales and engineering support</p><h2>{title}</h2><p>{text}</p></div>
  <div class="actions"><a class="button light" href={mailto(subject)}>{label}</a><a class="text-link" href={`mailto:${site.email}`}>{site.email}</a></div>
</section>
